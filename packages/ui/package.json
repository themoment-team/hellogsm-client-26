    "react-hook-form": "^7.71.1",
    "react-toastify": "^11.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.2"
  }
