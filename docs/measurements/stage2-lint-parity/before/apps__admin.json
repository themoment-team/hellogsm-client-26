    "source": "'use client';\r\n\r\nimport { useGetAdmissionTickets } from '@repo/api/hooks';\r\nimport {\r\n  NEXT_YEAR,\r\n  passedMemberAnnounceDate,\r\n  visionCampDate,\r\n  심층면접시험기간,\r\n  역량검사시험기간,\r\n} from '@repo/constants';\r\nimport { TicketType } from '@repo/types';\r\nimport { PrintIcon } from '@repo/ui/icons';\r\nimport { Button } from '@repo/ui/shadcn';\r\nimport { cn } from '@repo/utils';\r\n\r\ninterface TicketPageProps {\r\n  initialData: TicketType[];\r\n}\r\n\r\nconst TicketPage = ({ initialData }: TicketPageProps) => {\r\n  const { data: admissionTickets } = useGetAdmissionTickets({\r\n    initialData: initialData,\r\n  });\r\n\r\n  const handlePrint = () => {\r\n    window.print();\r\n  };\r\n\r\n  return (\r\n    <div className={cn('print:exact', 'flex', 'flex-col', 'bg-white', 'print:pt-0')}>\r\n      {admissionTickets?.map((ticket) => (\r\n        <div\r\n          key={ticket.oneseoSubmitCode}\r\n          className={cn(\r\n            'mx-auto',\r\n            'flex',\r\n            'h-[100dvh]',\r\n            'w-[920px]',\r\n            'items-center',\r\n            'font-normal',\r\n            'text-black',\r\n          )}\r\n        >\r\n          <table\r\n            className={cn(\r\n              'h-[350px]',\r\n              'w-full',\r\n              'border-collapse',\r\n              'text-center',\r\n              'text-[0.75rem]',\r\n              'font-light',\r\n              'leading-[1.25rem]',\r\n            )}\r\n          >\r\n            <tbody>\r\n              <tr>\r\n                <td\r\n                  className={cn('w-[55vw]', 'border', 'border-black', 'text-[20px]', 'font-normal')}\r\n                  colSpan={2}\r\n                >\r\n                  수험자 안내사항\r\n                </td>\r\n                <td\r\n                  className={cn('w-[45vw]', 'border', 'border-black', 'text-[20px]', 'font-normal')}\r\n                  colSpan={3}\r\n                >\r\n                  수 험 표\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td className={cn('w-28', 'border', 'border-black', 'font-normal')}>\r\n                  2차 전형 <br />\r\n                  (역량검사)\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  {역량검사시험기간}\r\n                </td>\r\n\r\n                <td rowSpan={7} className={cn('h-[200px]', 'w-[150px]', 'border', 'border-black')}>\r\n                  {ticket.profileImg && (\r\n                    <img\r\n                      src={ticket.profileImg}\r\n                      alt=\"증명사진 오류\"\r\n                      className={cn('block', 'h-full', 'w-full')}\r\n                    />\r\n                  )}\r\n                </td>\r\n                <td\r\n                  rowSpan={1}\r\n                  className={cn(\r\n                    'w-[10%]',\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  접수번호\r\n                </td>\r\n                <td rowSpan={1} className={cn('border', 'border-black', 'font-normal')}>\r\n                  {ticket.oneseoSubmitCode}\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td className={cn('w-28', 'border', 'border-black', 'font-normal')}>\r\n                  2차 전형 <br />\r\n                  (심층면접)\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  {심층면접시험기간}\r\n                </td>\r\n                <td\r\n                  rowSpan={1}\r\n                  className={cn(\r\n                    'w-[10%]',\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  수험번호\r\n                </td>\r\n                <td rowSpan={1} className={cn('border', 'border-black', 'font-normal')}>\r\n                  {ticket.examinationNumber}\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td rowSpan={2} className={cn('border', 'border-black', 'font-normal')}>\r\n                  합격자 발표\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  입학지원 사이트 로그인 후 확인(hellogsm.kr)\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  성명\r\n                </td>\r\n                <td className={cn('border', 'border-black')}>{ticket.memberName}</td>\r\n              </tr>\r\n              <tr>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  {passedMemberAnnounceDate}\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                  rowSpan={2}\r\n                >\r\n                  생년월일\r\n                </td>\r\n                <td className={cn('border', 'border-black', 'font-normal')} rowSpan={2}>\r\n                  {ticket.memberBirth}\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td rowSpan={2} className={cn('border', 'border-black', 'font-normal')}>\r\n                  합격자 등록 및<br /> 서류 제출\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  공문 시행, 방문 제출\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  (1) 입학등록동의서 1부\r\n                  <br />\r\n                  (2) 건강진단서 1부\r\n                  <br />\r\n                  2025. 11. 05.(수)~ 11. 10.(월) 16:30\r\n                  <br />\r\n                  (※ 휴무일과 공휴일은 서류 접수하지 않음)\r\n                </td>\r\n                <td\r\n                  rowSpan={2}\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  출신학교\r\n                </td>\r\n                {ticket.schoolName ? (\r\n                  <td rowSpan={2} className={cn('border', 'border-black')}>\r\n                    {ticket.schoolName}\r\n                  </td>\r\n                ) : (\r\n                  <td\r\n                    rowSpan={2}\r\n                    className={cn(\r\n                      'bg-[url(&apos;data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\"><line x1=\"0\" y1=\"100%\" x2=\"100%\" y2=\"0\" stroke=\"gray\" /></svg>&apos;)]',\r\n                      'border',\r\n                      'border-black',\r\n                    )}\r\n                  />\r\n                )}\r\n              </tr>\r\n              <tr>\r\n                <td className={cn('border', 'border-black', 'font-normal')}>입학등록동의서 서식</td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  본교 홈페이지에서 다운로드\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td className={cn('border', 'border-black', 'font-normal')}>신입생 비전캠프</td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  {visionCampDate.startDate} ~ {visionCampDate.endDate} 예정\r\n                </td>\r\n                <td\r\n                  rowSpan={2}\r\n                  colSpan={2}\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-2',\r\n                    'pr-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  위 사람은 {NEXT_YEAR}학년도 <br /> 본교 신입생 입학전형 지원자임을 확인함.\r\n                  <p className={cn('pr-[0.625rem]', 'text-center', 'font-normal')}>\r\n                    2025년 10월 31일\r\n                  </p>\r\n                  <p>광주소프트웨어마이스터고등학교장 [직인생략]</p>\r\n                </td>\r\n                <td\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'bg-[#e9e9e9]',\r\n                    'font-medium',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  접수자\r\n                </td>\r\n              </tr>\r\n              <tr>\r\n                <td\r\n                  colSpan={2}\r\n                  className={cn(\r\n                    'border',\r\n                    'border-black',\r\n                    'pl-[0.625rem]',\r\n                    'text-left',\r\n                    'font-normal',\r\n                  )}\r\n                >\r\n                  * 공지 사항: 홈페이지(gsm.gen.hs.kr)-입학 안내 <br />* 문의:062-949-6842\r\n                </td>\r\n                <td className={cn('border', 'border-black', 'font-normal')}>(인)</td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      ))}\r\n      <Button\r\n        className={cn(\r\n          'fixed',\r\n          'bottom-10',\r\n          'right-10',\r\n          'z-50',\r\n          'items-center',\r\n          'gap-2',\r\n          'print:hidden',\r\n        )}\r\n        onClick={handlePrint}\r\n      >\r\n        <PrintIcon />\r\n        <p className={cn('text-[2.1vh]', 'font-bold', 'hover:text-white')}>인쇄하기</p>\r\n      </Button>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default TicketPage;\r\n",
